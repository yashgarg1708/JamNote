PORT=8000
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority

JWT_ACCESS_SECRET=replace_with_strong_random_access_secret
JWT_REFRESH_SECRET=replace_with_strong_random_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

COOKIE_SECURE=false
COOKIE_DOMAIN=

# Comma-separated origins. Leave empty to allow all.
CORS_ORIGINS=
SOCKET_CORS_ORIGINS=

# Set this in production so reset links point to your frontend.
FRONTEND_URL=http://localhost:5173

# Optional (Resend mailer for password reset)
RESEND_API_KEY=
MAIL_FROM=JamNotes <onboarding@resend.dev>
